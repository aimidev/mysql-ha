[maxscale]
threads=auto
log_augmentation=1

[MySQL-Monitor]
type=monitor
module=mysqlmon
servers=mysql-primary
user=maxscale
password=FlimTrack2024!User
monitor_interval=2000

[Read-Write-Service]
type=service
router=readwritesplit
servers=mysql-primary
user=maxscale
password=FlimTrack2024!User
max_connections=2000

[Read-Write-Listener]
type=listener
service=Read-Write-Service
protocol=MySQLClient
port=4006
address=0.0.0.0

[CLI]
type=service
router=cli

[CLI-Listener]
type=listener
service=CLI
protocol=maxscaled
address=0.0.0.0
port=6603

[mysql-primary]
type=server
address=mysql-primary
port=3306
protocol=MySQLBackend
